{"ast":null,"code":"export class InventoryService{constructor(productId,onUpdate){this.productId=productId;this.onUpdate=onUpdate;this.ws=null;this.reconnectAttempts=0;this.maxReconnectAttempts=5;}connect(){const wsUrl=\"\".concat(process.env.REACT_APP_WS_URL,\"/ws/inventory/\").concat(this.productId,\"/\");this.ws=new WebSocket(wsUrl);this.ws.onopen=()=>{this.reconnectAttempts=0;this.ws.send(JSON.stringify({action:'get_stock'}));};this.ws.onmessage=event=>{const data=JSON.parse(event.data);if(data.type==='stock_update'){this.onUpdate(data);}};this.ws.onclose=()=>{if(this.reconnectAttempts<this.maxReconnectAttempts){setTimeout(()=>{this.reconnectAttempts++;this.connect();},3000*this.reconnectAttempts);}};this.ws.onerror=error=>{console.error('WebSocket error:',error);};}disconnect(){if(this.ws){this.ws.close();}}}","map":{"version":3,"names":["InventoryService","constructor","productId","onUpdate","ws","reconnectAttempts","maxReconnectAttempts","connect","wsUrl","concat","process","env","REACT_APP_WS_URL","WebSocket","onopen","send","JSON","stringify","action","onmessage","event","data","parse","type","onclose","setTimeout","onerror","error","console","disconnect","close"],"sources":["C:/Users/upput/Downloads/vitejs-vite-xc3va9lg/src/services/inventoryservices.js"],"sourcesContent":["export class InventoryService {\r\n  constructor(productId, onUpdate) {\r\n    this.productId = productId;\r\n    this.onUpdate = onUpdate;\r\n    this.ws = null;\r\n    this.reconnectAttempts = 0;\r\n    this.maxReconnectAttempts = 5;\r\n  }\r\n\r\n  connect() {\r\n    const wsUrl = `${process.env.REACT_APP_WS_URL}/ws/inventory/${this.productId}/`;\r\n    this.ws = new WebSocket(wsUrl);\r\n\r\n    this.ws.onopen = () => {\r\n      this.reconnectAttempts = 0;\r\n      this.ws.send(JSON.stringify({ action: 'get_stock' }));\r\n    };\r\n\r\n    this.ws.onmessage = (event) => {\r\n      const data = JSON.parse(event.data);\r\n      if (data.type === 'stock_update') {\r\n        this.onUpdate(data);\r\n      }\r\n    };\r\n\r\n    this.ws.onclose = () => {\r\n      if (this.reconnectAttempts < this.maxReconnectAttempts) {\r\n        setTimeout(() => {\r\n          this.reconnectAttempts++;\r\n          this.connect();\r\n        }, 3000 * this.reconnectAttempts);\r\n      }\r\n    };\r\n\r\n    this.ws.onerror = (error) => {\r\n      console.error('WebSocket error:', error);\r\n    };\r\n  }\r\n\r\n  disconnect() {\r\n    if (this.ws) {\r\n      this.ws.close();\r\n    }\r\n  }\r\n}\r\n"],"mappings":"AAAA,MAAO,MAAM,CAAAA,gBAAiB,CAC5BC,WAAWA,CAACC,SAAS,CAAEC,QAAQ,CAAE,CAC/B,IAAI,CAACD,SAAS,CAAGA,SAAS,CAC1B,IAAI,CAACC,QAAQ,CAAGA,QAAQ,CACxB,IAAI,CAACC,EAAE,CAAG,IAAI,CACd,IAAI,CAACC,iBAAiB,CAAG,CAAC,CAC1B,IAAI,CAACC,oBAAoB,CAAG,CAAC,CAC/B,CAEAC,OAAOA,CAAA,CAAG,CACR,KAAM,CAAAC,KAAK,IAAAC,MAAA,CAAMC,OAAO,CAACC,GAAG,CAACC,gBAAgB,mBAAAH,MAAA,CAAiB,IAAI,CAACP,SAAS,KAAG,CAC/E,IAAI,CAACE,EAAE,CAAG,GAAI,CAAAS,SAAS,CAACL,KAAK,CAAC,CAE9B,IAAI,CAACJ,EAAE,CAACU,MAAM,CAAG,IAAM,CACrB,IAAI,CAACT,iBAAiB,CAAG,CAAC,CAC1B,IAAI,CAACD,EAAE,CAACW,IAAI,CAACC,IAAI,CAACC,SAAS,CAAC,CAAEC,MAAM,CAAE,WAAY,CAAC,CAAC,CAAC,CACvD,CAAC,CAED,IAAI,CAACd,EAAE,CAACe,SAAS,CAAIC,KAAK,EAAK,CAC7B,KAAM,CAAAC,IAAI,CAAGL,IAAI,CAACM,KAAK,CAACF,KAAK,CAACC,IAAI,CAAC,CACnC,GAAIA,IAAI,CAACE,IAAI,GAAK,cAAc,CAAE,CAChC,IAAI,CAACpB,QAAQ,CAACkB,IAAI,CAAC,CACrB,CACF,CAAC,CAED,IAAI,CAACjB,EAAE,CAACoB,OAAO,CAAG,IAAM,CACtB,GAAI,IAAI,CAACnB,iBAAiB,CAAG,IAAI,CAACC,oBAAoB,CAAE,CACtDmB,UAAU,CAAC,IAAM,CACf,IAAI,CAACpB,iBAAiB,EAAE,CACxB,IAAI,CAACE,OAAO,CAAC,CAAC,CAChB,CAAC,CAAE,IAAI,CAAG,IAAI,CAACF,iBAAiB,CAAC,CACnC,CACF,CAAC,CAED,IAAI,CAACD,EAAE,CAACsB,OAAO,CAAIC,KAAK,EAAK,CAC3BC,OAAO,CAACD,KAAK,CAAC,kBAAkB,CAAEA,KAAK,CAAC,CAC1C,CAAC,CACH,CAEAE,UAAUA,CAAA,CAAG,CACX,GAAI,IAAI,CAACzB,EAAE,CAAE,CACX,IAAI,CAACA,EAAE,CAAC0B,KAAK,CAAC,CAAC,CACjB,CACF,CACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}